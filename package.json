{
  "name": "tp-manager",
  "private": true,
  "version": "0.1.0",
  "description": "TP Manager — Restaurant Operations Platform (spec v1.6)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "@types/node": "^20.16.5",
    "eslint": "^9.11.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@tp/tp": "workspace:*"
  }
}
