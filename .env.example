# Copy to .env for local dev. Secrets in prod come from Key Vault via managed identity.

# -------- Postgres --------
DATABASE_URL=postgres://tp:tp_local_dev@postgres:5432/tp_manager
POSTGRES_USER=tp
POSTGRES_PASSWORD=tp_local_dev
POSTGRES_DB=tp_manager

# -------- Blob (MinIO locally, Azure Blob in prod) --------
BLOB_ENDPOINT=http://minio:9000
BLOB_ACCESS_KEY=tp_minio_admin
BLOB_SECRET_KEY=tp_minio_local_dev
BLOB_BUCKET=tp-manager

# -------- API --------
NODE_ENV=development
LOG_LEVEL=debug
PORT=3001
HOST=0.0.0.0
APP_VERSION=0.1.0

# -------- Auth (TASK-029) --------
# Generate with: openssl rand -hex 32 (must be >= 32 chars)
JWT_ACCESS_SECRET=dev-only-change-me-dev-only-change-me-xx
# Cookie signing — falls back to JWT_ACCESS_SECRET when unset.
COOKIE_SECRET=
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# -------- ML service --------
ML_BASE_URL=http://ml:8000

# -------- App Insights (prod) --------
APPLICATIONINSIGHTS_CONNECTION_STRING=

# -------- Feature flag overrides (TASK-013) --------
# FF_OVERRIDE_ML_ENABLED=false
# FF_OVERRIDE_OPERATIONAL_ORDERS=true
